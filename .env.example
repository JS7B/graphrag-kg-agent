# 复制为 .env 后填入真实值；.env 已被 .gitignore 忽略，切勿提交真实密钥。

# ── LLM（OpenAI-compatible，不绑定具体厂商）──
# embedding/rerank 走 OPENAI_* 这组（如 modelverse）。
OPENAI_BASE_URL=https://your-provider/v1
OPENAI_API_KEY=sk-your-key-here

# chat 可单独走另一家（如 DeepSeek 官方）。留空则回退上面的 OPENAI_*，等于 chat/embed 同 provider。
# 分离的好处：切 chat 厂商不影响已入库的向量索引（embedding 维度不变）。
CHAT_BASE_URL=https://api.deepseek.com
CHAT_API_KEY=sk-your-deepseek-key-here

# CHAT_MODEL 需支持 JSON 输出模式（response_format json_object，用于实体关系抽取）
# 和 function calling（Agentic RAG 的 tool calling）。
CHAT_MODEL=deepseek-chat
EMBEDDING_MODEL=your-embedding-model
# embedding 向量维度，必须与 EMBEDDING_MODEL 实际输出维度一致（建向量索引时用）。
# 例：text-embedding-3-large=3072，text-embedding-ada-002=1536。
EMBEDDING_DIM=3072
# rerank 模型，用于问答时对召回 chunk 重排（OpenAI-compatible /rerank 端点）。
RERANK_MODEL=bge-reranker-v2-m3

# ── Neo4j（需与 docker-compose.yml 保持一致）──
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me

# ── 文档上传 ──
# 单文件上传大小上限（MB）。超出返回 413。够样本用，日后可调。
MAX_UPLOAD_MB=10
# PDF 页数上限，防 PDF 炸弹（整本解析进内存）。
MAX_PDF_PAGES=200

# ── 安全（PR 审计加固）──
# API Key 鉴权：填值则所有接口（/health 除外）需带请求头 X-API-Key。
# 留空 = 开发模式不校验，本地直接跑。公开部署务必填。
API_KEY=
# CORS 允许来源（逗号分隔）。默认仅本地前端；公开部署填真实前端域名，勿用 *。
CORS_ORIGINS=http://localhost:5173
