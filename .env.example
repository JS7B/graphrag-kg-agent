# 复制为 .env 后填入真实值；.env 已被 .gitignore 忽略，切勿提交真实密钥。

# ── LLM（OpenAI-compatible，不绑定具体厂商）──
OPENAI_BASE_URL=https://your-provider/v1
OPENAI_API_KEY=sk-your-key-here
# CHAT_MODEL 需支持 JSON 输出模式（response_format json_object），用于实体关系抽取。
CHAT_MODEL=your-chat-model
EMBEDDING_MODEL=your-embedding-model
# embedding 向量维度，必须与 EMBEDDING_MODEL 实际输出维度一致（建向量索引时用）。
# 例：text-embedding-3-large=3072，text-embedding-ada-002=1536。
EMBEDDING_DIM=3072

# ── Neo4j（需与 docker-compose.yml 保持一致）──
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me
